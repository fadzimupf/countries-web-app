{
  "runtime": "Net90",
    "documentGenerator": {
    "fromDocument": {
      "url": "docs/country-api.yaml",
      "output": null
    }
  },
  "codeGenerators": {
    "openApiToCSharpController": {
      "controllerBaseClass": "Microsoft.AspNetCore.Mvc.ControllerBase",
      "controllerStyle": "Abstract",
      "controllerTarget": "AspNetCore",
      "className": "CountriesControllerBase",
      "generateModelClasses": true,
      "generateDataAnnotations": true,
      "namespace": "CountriesApplication.Server.Controllers.Generated",
      "output": "Controllers/Generated/CountriesControllerBase.cs",
      "generateDefaultValues": true,
      "requiredPropertiesMustBeDefined": true,
      "dateType": "DateTimeOffset"
    }
  }
}